{
  "name": "@spoton/ai-pr-reviewer",
  "version": "0.1.0",
  "description": "Risk-tiered AI PR reviewer for the SpotOn Accelerate team.",
  "private": true,
  "type": "module",
  "bin": {
    "ai-review": "./dist/cli.js"
  },
  "scripts": {
